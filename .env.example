# ──────────────────────────────────────────────────────────────
# AI Cargo Monitor — Environment Configuration
# Copy this file to .env and fill in your values.
# .env is listed in .gitignore and will NEVER be committed.
# ──────────────────────────────────────────────────────────────

# Anthropic API key — required for real Claude AI responses
# Get yours at: https://console.anthropic.com/
# Leave as placeholder if using DEMO_MODE=true
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Demo Mode ──────────────────────────────────────────────────
# Set to true to run the full pipeline with pre-scripted AI responses.
# No API key needed. Perfect for demos, CI, and local testing.
# Set to false (or remove) to use real Claude AI calls.
DEMO_MODE=false

# ── App config ────────────────────────────────────────────────
DATABASE_URL=cargo.db
TELEMETRY_POLL_INTERVAL=30
HITL_TIMEOUT_MINUTES=15
MAX_TELEMETRY_WINDOW=50
LOG_LEVEL=INFO
DASHBOARD_PORT=8501
API_PORT=8000

# ── LangGraph ─────────────────────────────────────────────────
# Silences deserialization warnings for custom Pydantic models
LANGGRAPH_ALLOWED_MSGPACK_MODULES=src.graph.state
